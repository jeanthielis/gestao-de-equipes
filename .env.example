# Copie este arquivo para .env e preencha com suas credenciais do Supabase
# Nunca commite o arquivo .env no repositório

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Domínio de e-mail gerado automaticamente no cadastro de usuários
# Padrão usado como fallback: @safetrack.com.br
VITE_EMAIL_DOMAIN=@suaempresa.com.br
